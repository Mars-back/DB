generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model appointment {
  appointment_id      Int                   @id @default(autoincrement())
  date_time           DateTime              @db.Timestamp(6)
  patient_id          Int
  doctor_id           Int
  doctor              doctor                @relation(fields: [doctor_id], references: [doctor_id], onDelete: NoAction, onUpdate: NoAction)
  patient             patient               @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction)
  appointment_details appointment_details[]
}

model appointment_details {
  appointment_details_id Int         @id @default(autoincrement())
  appointment_id         Int
  service_id             Int
  appointment            appointment @relation(fields: [appointment_id], references: [appointment_id], onDelete: NoAction, onUpdate: NoAction)
  service                service     @relation(fields: [service_id], references: [service_id], onDelete: NoAction, onUpdate: NoAction)
}

model doctor {
  doctor_id        Int                @id @default(autoincrement())
  staff_type       type_of_staff      @default(dbgenerated("спеціаліст"))
  people_id        Int                @unique
  appointment      appointment[]
  people           people             @relation(fields: [people_id], references: [people_id], onDelete: NoAction, onUpdate: NoAction)
  doctor_specialty doctor_specialty[]
}

model doctor_specialty {
  doctor_id    Int
  specialty_id Int
  doctor       doctor    @relation(fields: [doctor_id], references: [doctor_id], onDelete: NoAction, onUpdate: NoAction)
  specialty    specialty @relation(fields: [specialty_id], references: [specialty_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([doctor_id, specialty_id])
}

model patient {
  patient_id  Int            @id @default(autoincrement())
  gender      patient_gender
  type_client client_type    @default(dbgenerated("пацієнт"))
  people_id   Int            @unique
  appointment appointment[]
  people      people         @relation(fields: [people_id], references: [people_id], onDelete: NoAction, onUpdate: NoAction)
}

model people {
  people_id    Int      @id @default(autoincrement())
  first_name   String   @db.VarChar(25)
  last_name    String   @db.VarChar(32)
  birth_date   DateTime @db.Date
  phone_number String   @unique @db.Char(12)
  email        String   @unique @db.VarChar(64)
  doctor       doctor?
  patient      patient?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model service {
  service_id            Int                     @id @default(autoincrement())
  category_id           Int
  title                 String                  @unique @db.VarChar(100)
  price                 Decimal                 @db.Decimal(10, 2)
  duration              Unsupported("interval")
  appointment_details   appointment_details[]
  service_category_dict service_category_dict   @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
}

model service_category_dict {
  category_id Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  service     service[]
}

model specialty {
  specialty_id     Int                @id @default(autoincrement())
  title            String             @unique @db.VarChar(50)
  doctor_specialty doctor_specialty[]
}

enum client_type {
  PATIENT     @map("пацієнт")
  VIP         @map("VIP") 
  CORPORATE   @map("корпоративний клієнт")
  INSURANCE   @map("страховий пацієнт")
}

enum patient_gender {
  MALE   @map("чоловік")
  FEMALE @map("жінка")
}

enum type_of_staff {
  ASSISTANT  @map("асистент")
  REFERRING  @map("направник")
  SPECIALIST @map("спеціаліст")
}
